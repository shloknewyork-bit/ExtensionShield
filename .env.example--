# Project Atlas Environment Configuration

# =============================================================================
# LLM Provider Configuration (Required)
# =============================================================================
# Options: openai, watsonx, ollama, rits
LLM_PROVIDER=openai

# Model name (varies by provider)
# OpenAI: gpt-4o, gpt-4-turbo
# WatsonX: meta-llama/llama-3-3-70b-instruct
# Ollama: llama3, mistral
# RITS: meta-llama/llama-3-3-70b-instruct
LLM_MODEL=gpt-4o

# =============================================================================
# OpenAI Configuration (Required if LLM_PROVIDER=openai)
# =============================================================================
OPENAI_API_KEY=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

# =============================================================================
# WatsonX Configuration (Required if LLM_PROVIDER=watsonx)
# =============================================================================
WATSONX_API_KEY=your-watsonx-api-key-here
WATSONX_API_ENDPOINT=https://us-south.ml.cloud.ibm.com
WATSONX_PROJECT_ID=your-project-id-here

# =============================================================================
# RITS Configuration (Required if LLM_PROVIDER=rits)
# =============================================================================
RITS_API_BASE_URL=https://your-rits-endpoint.com
RITS_API_KEY=your-rits-api-key-here

# =============================================================================
# Ollama Configuration (Required if LLM_PROVIDER=ollama)
# =============================================================================
# Ollama runs locally, no API key needed
# Make sure Ollama is running on your machine

# =============================================================================
# Optional: VirusTotal Integration
# =============================================================================
VIRUSTOTAL_API_KEY=84c16b9853a293618f9cfb7a58645df0a33bd587b9fee93165b4e056259e0c1e

# =============================================================================
# Optional: LangSmith Tracing (for LLM debugging)
# =============================================================================
LANGSMITH_API_KEY=your-langsmith-api-key-here

# =============================================================================
# Storage Configuration (Optional - defaults provided)
# =============================================================================
# EXTENSION_STORAGE_PATH=./extensions_storage
# DATABASE_PATH=./data/project-atlas.db
