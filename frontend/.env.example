# ==============================================================================
# ExtensionShield Frontend - Environment Variables Example
# ==============================================================================
# Copy this file to .env or .env.local for local development
# DO NOT commit .env files to version control (they're in .gitignore)
# ==============================================================================

# ------------------------------------------------------------------------------
# Supabase Configuration (REQUIRED for authentication)
# ------------------------------------------------------------------------------
# These are build-time variables (Vite requires VITE_ prefix)
# They are baked into the frontend bundle at build time.

# Get these values from: https://app.supabase.com
# 1. Go to your project dashboard
# 2. Click 'Settings' (gear icon) in the left sidebar
# 3. Click 'API' under Project Settings
# 4. Copy the 'Project URL' → this is your VITE_SUPABASE_URL
# 5. Copy the 'anon' or 'public' key → this is your VITE_SUPABASE_ANON_KEY
#
# For email sign-in/sign-up: In Supabase Dashboard go to
# Authentication → Providers → Email and ensure "Enable Email provider" is ON.
# You can toggle "Confirm email" if you want users to verify their email before signing in.

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ------------------------------------------------------------------------------
# API Configuration (Optional - for local development)
# ------------------------------------------------------------------------------
# Only needed if running frontend separately from backend (e.g., Vite dev server)
# In production, frontend is served by the FastAPI backend (same origin)

# For local development with separate frontend/backend servers:
# VITE_API_URL=http://localhost:8007

# For production (frontend served by backend), leave empty or unset
# VITE_API_URL=

# ------------------------------------------------------------------------------
# Debug / Testing (Optional)
# ------------------------------------------------------------------------------
# Enable auth diagnostics page (for debugging authentication issues)
# VITE_DEBUG_AUTH=false

# Require sign-in to scan even in development (to test auth flow locally)
# Set to true to verify "login required to scan" without a production build
# VITE_REQUIRE_AUTH_FOR_SCAN=false
