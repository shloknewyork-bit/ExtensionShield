{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "author": "Stanzin",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run generate:sitemap && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "generate:sitemap": "node scripts/generate-sitemap.js",
    "export:logo": "node scripts/export-logo-png.mjs",
    "contrast:audit": "node scripts/contrast-audit.js",
    "seo:test": "node scripts/seo_smoke_test.mjs --prod",
    "seo:test:local": "node scripts/seo_smoke_test.mjs --local",
    "seo:prod:reality": "node scripts/seo_prod_reality_check.mjs",
    "seo:prod:reality:scanner": "REDIRECT_DOMAINS=extensionscanner.com node scripts/seo_prod_reality_check.mjs",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:visual": "playwright test --config=playwright.config.cjs",
    "test:visual:update": "playwright test --config=playwright.config.cjs --update-snapshots",
    "ci:check": "npm run build && npm run audit:ci && npm run seo:test:ci",
    "audit:ci": "npm audit --audit-level=high",
    "seo:test:ci": "SEO_SKIP_ROBOTS_TXT=1 TEST_PAGES='/,/scan,/enterprise,/research/methodology,/research/case-studies' node scripts/seo_smoke_test.mjs --prod"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/supabase-js": "^2.94.1",
    "axios": "^1.12.2",
    "framer-motion": "^12.34.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^7.9.4",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "jsdom": "^23.0.1",
    "lucide-react": "^0.562.0",
    "playwright": "^1.49.0",
    "postcss": "^8.5.6",
    "prettier": "^3.4.2",
    "sass": "^1.97.2",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "tailwindcss-animate": "^1.0.7",
    "vite": "^7.3.2",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "flat-cache": {
      "flatted": "3.4.2"
    },
    "micromatch": {
      "picomatch": "2.3.2"
    },
    "minimatch": {
      "brace-expansion": "1.1.13"
    },
    "tinyglobby": {
      "picomatch": "4.0.4"
    },
    "vite": {
      "picomatch": "4.0.4"
    }
  }
}
