# ==============================================================================
# Project Atlas - Production Environment Variables
# ==============================================================================
# Copy this file to .env for local development
# For Railway/production, set these as environment variables in your dashboard
# ==============================================================================

# ------------------------------------------------------------------------------
# LLM Configuration (REQUIRED - choose one provider)
# ------------------------------------------------------------------------------

# LLM Provider: openai, watsonx, rits, ollama
LLM_PROVIDER=openai

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
LLM_MODEL=gpt-4o

# OR WatsonX Configuration (IBM Cloud)
# LLM_PROVIDER=watsonx
# WATSONX_API_KEY=your-watsonx-api-key
# WATSONX_PROJECT_ID=your-project-id
# WATSONX_URL=https://us-south.ml.cloud.ibm.com

# OR RITS Configuration (Red Hat)
# LLM_PROVIDER=rits
# RITS_API_KEY=your-rits-api-key
# RITS_URL=https://api.rits.example.com

# OR Ollama Configuration (Self-hosted)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434

# ------------------------------------------------------------------------------
# Optional Integrations
# ------------------------------------------------------------------------------

# VirusTotal API (optional - for malware hash checking)
# Get your free API key at: https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=

# ------------------------------------------------------------------------------
# Application Configuration
# ------------------------------------------------------------------------------

# Storage paths (usually set by Docker/Railway automatically)
EXTENSION_STORAGE_PATH=/app/extensions_storage
DATABASE_PATH=/app/data/project-atlas.db

# Server port (Railway sets PORT automatically, but we default to 8007)
PORT=8007

# ------------------------------------------------------------------------------
# Production-Only Settings
# ------------------------------------------------------------------------------

# Your custom domain (if configured in Railway)
# CUSTOM_DOMAIN=project-atlas.yourdomain.com

# Enable production mode
# ENVIRONMENT=production

# CORS allowed origins (comma-separated, or * for all)
# CORS_ORIGINS=https://project-atlas.yourdomain.com,https://project-atlas.up.railway.app


