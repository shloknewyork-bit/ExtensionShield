# Proprietary intel (do not commit contents of data/intel except README and .gitignore)
/data/intel/*
!/data/intel/README.md
!/data/intel/.gitignore

# Internal QA exports (do not commit; remove from tracking if already committed)
docs/qa_extensionshield/
