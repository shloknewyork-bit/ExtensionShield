{
   "action": {
      "default_icon": {
         "16": "icons/16.png",
         "32": "icons/32.png",
         "48": "icons/48.png"
      },
      "default_title": "ExtensionShield – Extension Security Scanner"
   },
   "background": {
      "service_worker": "background.js"
   },
   "content_security_policy": {
      "extension_pages": "script-src 'self'; object-src 'self'"
   },
   "description": "Free security check for installed Chrome extensions: risky permissions, privacy signals, and a simple score. No account required.",
   "host_permissions": [ "https://extensionshield.com/*" ],
   "icons": {
      "128": "icons/128.png",
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "Extension Shield",
   "permissions": [ "storage" ],
   "optional_permissions": [ "management" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.1.0"
}
